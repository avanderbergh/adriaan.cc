---
const perforation = "dashed #ccc 1px";

type Colors = "white" | "canary" | "pink" | "blue";

const colors: Record<Colors, string> = {
    // NCR carbon copy paper colors (white, canary, pink, blue)
    white: "#f5f5f5",
    canary: "#fff9c4",
    pink: "#ffccbc",
    blue: "#bbdefb",
};

interface Props {
    id: string;
    color: Colors;
    title?: string;
    rotation: number;
    number?: number;
}

const { id, color, title, rotation, number } = Astro.props;

const c = colors[color];
---

<style define:vars={{ perforation, c }}>
    .paper {
        position: relative;
        padding: var(--marginSize);
        background: var(--c);
        width: calc(100% - var(--marginSize) * 2);
        max-width: 920px;
        margin-bottom: var(--marginSize);
    }

    .paper::before,
    .paper::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 20px;
        background: var(--c);
        background-image: radial-gradient(
            circle,
            var(--bg) 30%,
            var(--c) 31%
        );
        background-size: 10px 30px;
        background-repeat: repeat-y;
        background-position: center;
        z-index: 1;
    }

    .paper::before {
        left: calc(var(--marginSize) * -1);
        border-right: var(--perforation);
    }

    .paper::after {
        right: calc(var(--marginSize) * -1);
        border-left: var(--perforation);
    }

    .copy-number {
        position: absolute;
        left: calc(var(--marginSize) * -1 + 18px);
        top: 50%;
        transform: translateY(-50%) rotate(-90deg);
        transform-origin: center;
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--fg);
        opacity: 0.2;
        z-index: 2;
        user-select: none;
        pointer-events: none;
        white-space: nowrap;
        letter-spacing: -2px;
    }

    .title {
        text-wrap: nowrap;
        text-align: center;
        margin: var(--marginSize);
    }

    footer {
        padding: var(--marginSize);
        display: flex;
        justify-content: flex-end;
        /* From 48px to 56px */
        font-size: clamp(3rem, 2.5rem + 2vw, 3.5rem);

        a {
            color: var(--fg);
            text-decoration: none;
        }
    }
</style>

<div class="paper" id={id} style={{ transform: `rotate(${rotation}deg)` }}>
    {number && <span class="copy-number">{number}</span>}
    {title && <h1 class="title">{title}</h1>}
    <slot />
    <footer>
        <a href="#top" aria-label="Back to top">▲</a>
    </footer>
</div>