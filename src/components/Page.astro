---
type Colors = "white" | "canary" | "pink" | "blue";

const colors: Record<Colors, string> = {
    // NCR carbonless paper colors (white, canary, pink, blue)
    white: "#f5f5f5",
    canary: "#fff9c4",
    pink: "#f8d7e8",
    blue: "#bbdefb",
};

interface Props {
    id: string;
    color: Colors;
    title?: string;
    rotation: number;
}

const { id, color, title, rotation } = Astro.props;

const c = colors[color];
---

<style define:vars={{ c }}>
    .paper {
        position: relative;
        padding: var(--marginSize);
        background: var(--c);
        width: calc(100% - var(--marginSize) * 2);
        max-width: 920px;
        margin-bottom: var(--marginSize);
    }

    .strip {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 20px;
        background: var(--c);
        background-image: radial-gradient(circle, var(--bg) 28%, var(--c) 29%);
        background-size: 10px 30px;
        background-repeat: repeat-y;
        background-position: center;
        z-index: 1;
    }

    .strip-left {
        left: calc(var(--marginSize) * -1);
    }

    .strip-right {
        right: calc(var(--marginSize) * -1);
    }

    /* Micro-perforation line on the inner edge of each strip */
    .strip-left::after,
    .strip-right::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 1px;
        background-image: repeating-linear-gradient(
            to bottom,
            transparent 0 3px,
            #999 3px 5px,
            transparent 5px 8px
        );
    }

    .strip-left::after {
        right: 0;
    }

    .strip-right::after {
        left: 0;
    }

    .title {
        text-wrap: nowrap;
        text-align: center;
        margin: var(--marginSize);
    }

    footer {
        padding: var(--marginSize);
        display: flex;
        justify-content: flex-end;
        /* From 48px to 56px */
        font-size: clamp(3rem, 2.5rem + 2vw, 3.5rem);

        a {
            color: var(--fg);
            text-decoration: none;
        }
    }
</style>

<div class="paper" id={id} style={{ transform: `rotate(${rotation}deg)` }}>
    <div class="strip strip-left"></div>
    <div class="strip strip-right"></div>
    {title && <h1 class="title">{title}</h1>}
    <slot />
    <footer>
        <a href="#top" aria-label="Back to top">▲</a>
    </footer>
</div>
