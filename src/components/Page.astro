---
type Colors = "white" | "canary" | "pink" | "blue";

const colors: Record<Colors, string> = {
    // NCR carbonless paper colors (white, canary, pink, blue)
    white: "#f5f5f5",
    canary: "#fff9c4",
    pink: "#fcd5d5",
    blue: "#bbdefb",
};

const copyLabels: Record<Colors, string> = {
    white: "ORIGINAL",
    canary: "DUPLICATE",
    pink: "TRIPLICATE",
    blue: "QUADRUPLICATE",
};

interface Props {
    id: string;
    color: Colors;
    title?: string;
    rotation: number;
    number?: number;
}

const { id, color, title, rotation, number } = Astro.props;

const c = colors[color];
const label = copyLabels[color];
const seq = number ? String(number).padStart(4, "0") : "0001";
---

<style define:vars={{ c }}>
    .paper {
        position: relative;
        padding: var(--marginSize);
        background: var(--c);
        width: calc(100% - var(--marginSize) * 2);
        max-width: 920px;
        margin-bottom: var(--marginSize);
    }

    .strip {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 20px;
        background: var(--c);
        background-image: radial-gradient(
            circle,
            var(--bg) 28%,
            var(--c) 29%
        );
        background-size: 10px 30px;
        background-repeat: repeat-y;
        background-position: center;
        z-index: 1;
    }

    .strip-left {
        left: calc(var(--marginSize) * -1);
    }

    .strip-right {
        right: calc(var(--marginSize) * -1);
    }

    /* Micro-perforation line on the inner edge of each strip */
    .strip-left::after,
    .strip-right::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 1px;
        background-image: repeating-linear-gradient(
            to bottom,
            transparent 0 3px,
            #999 3px 5px,
            transparent 5px 8px
        );
    }

    .strip-left::after {
        right: 0;
    }

    .strip-right::after {
        left: 0;
    }

    /* Small printed copy label on the left strip */
    .strip-label {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%) rotate(-90deg);
        white-space: nowrap;
        font-size: 9px;
        letter-spacing: 1px;
        color: var(--fg);
        opacity: 0.45;
        z-index: 2;
        user-select: none;
        pointer-events: none;
        text-align: center;
    }

    .strip-seq {
        position: absolute;
        right: 50%;
        top: 50%;
        transform: translate(50%, -50%) rotate(-90deg);
        white-space: nowrap;
        font-size: 8px;
        letter-spacing: 0.5px;
        color: var(--fg);
        opacity: 0.35;
        z-index: 2;
        user-select: none;
        pointer-events: none;
        text-align: center;
    }

    .title {
        text-wrap: nowrap;
        text-align: center;
        margin: var(--marginSize);
    }

    footer {
        padding: var(--marginSize);
        display: flex;
        justify-content: flex-end;
        /* From 48px to 56px */
        font-size: clamp(3rem, 2.5rem + 2vw, 3.5rem);

        a {
            color: var(--fg);
            text-decoration: none;
        }
    }
</style>

<div class="paper" id={id} style={{ transform: `rotate(${rotation}deg)` }}>
    <div class="strip strip-left">
        <span class="strip-label">{label}</span>
    </div>
    <div class="strip strip-right">
        <span class="strip-seq">N° {seq}</span>
    </div>
    {title && <h1 class="title">{title}</h1>}
    <slot />
    <footer>
        <a href="#top" aria-label="Back to top">▲</a>
    </footer>
</div>